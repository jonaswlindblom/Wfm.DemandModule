diff --git a/frontend/src/pages/SimulationPage.tsx b/frontend/src/pages/SimulationPage.tsx
new file mode 100644
index 0000000..0b80f35
--- /dev/null
+++ b/frontend/src/pages/SimulationPage.tsx
@@ -0,0 +1,292 @@
+import { useMemo, useState } from "react";
+import { useQuery } from "@tanstack/react-query";
+import {
+  Alert,
+  Box,
+  Button,
+  Card,
+  CardContent,
+  Divider,
+  FormControl,
+  InputLabel,
+  MenuItem,
+  Select,
+  Stack,
+  TextField,
+  Typography
+} from "@mui/material";
+import { ResponsiveContainer, LineChart, Line, XAxis, YAxis, Tooltip, Legend } from "recharts";
+import { api } from "../api/client";
+import type { Activity, LatestMappingResponse, SimulationCreateResponse, Stream, WorkloadBucket } from "../api/types";
+
+type ChartRow = { t: string } & Record<string, number>;
+
+export default function SimulationPage() {
+  const [streamId, setStreamId] = useState<string>("");
+  const [fromUtc, setFromUtc] = useState<string>(() => new Date(Date.now() - 24 * 3600 * 1000).toISOString());
+  const [toUtc, setToUtc] = useState<string>(() => new Date(Date.now()).toISOString());
+  const [intervalMinutes, setIntervalMinutes] = useState<number>(60);
+
+  const [simulationId, setSimulationId] = useState<string>("");
+  const [buckets, setBuckets] = useState<WorkloadBucket[]>([]);
+  const [selectedBucket, setSelectedBucket] = useState<WorkloadBucket | null>(null);
+  const [status, setStatus] = useState<string>("");
+  const [error, setError] = useState<string>("");
+
+  const streamsQ = useQuery({ queryKey: ["streams"], queryFn: () => api<Stream[]>("/streams") });
+  const activitiesQ = useQuery({ queryKey: ["activities"], queryFn: () => api<Activity[]>("/activities") });
+
+  const activityById = useMemo(() => {
+    const m: Record<string, Activity> = {};
+    for (const a of activitiesQ.data ?? []) m[a.id] = a;
+    return m;
+  }, [activitiesQ.data]);
+
+  const seriesKeys = useMemo(() => {
+    const ids = new Set(buckets.map(b => b.activityId));
+    return Array.from(ids).map(id => activityById[id]?.code ?? id);
+  }, [buckets, activityById]);
+
+  const chartData: ChartRow[] = useMemo(() => {
+    // Build rows keyed by intervalStart, with one field per activity code
+    const rows: Record<string, ChartRow> = {};
+    for (const b of buckets) {
+      const t = b.intervalStartUtc;
+      const code = activityById[b.activityId]?.code ?? b.activityId;
+      rows[t] = rows[t] ?? { t };
+      rows[t][code] = (rows[t][code] ?? 0) + b.hours;
+    }
+    return Object.values(rows).sort((a, b) => a.t.localeCompare(b.t));
+  }, [buckets, activityById]);
+
+  async function runSimulation() {
+    setError("");
+    setSelectedBucket(null);
+    setStatus("Loading latest mapping...");
+    try {
+      const latest = await api<LatestMappingResponse>(`/streams/${streamId}/mappings/latest`);
+      setStatus("Running simulation...");
+
+      const sim = await api<SimulationCreateResponse>(`/simulations`, {
+        method: "POST",
+        body: JSON.stringify({
+          streamId,
+          mappingVersionId: latest.version.id,
+          fromUtc,
+          toUtc,
+          intervalMinutes
+        })
+      });
+
+      setSimulationId(sim.simulationId);
+      setStatus("Fetching buckets...");
+      const rows = await api<WorkloadBucket[]>(`/simulations/${sim.simulationId}/buckets`);
+      setBuckets(rows);
+      setStatus("Done.");
+    } catch (e: any) {
+      setError(e?.message ?? String(e));
+      setStatus("");
+    }
+  }
+
+  return (
+    <Stack spacing={2}>
+      <Typography variant="h5">Simulation</Typography>
+      <Card>
+        <CardContent>
+          <Stack spacing={2}>
+            <Typography variant="subtitle1">1) Select stream + time range</Typography>
+            <Stack direction="row" spacing={2} flexWrap="wrap" alignItems="center">
+              <FormControl sx={{ minWidth: 360 }}>
+                <InputLabel id="stream-label">Stream</InputLabel>
+                <Select
+                  labelId="stream-label"
+                  label="Stream"
+                  value={streamId}
+                  onChange={(e) => setStreamId(String(e.target.value))}
+                >
+                  {(streamsQ.data ?? []).map(s => (
+                    <MenuItem key={s.id} value={s.id}>
+                      {s.name} ({s.industry})
+                    </MenuItem>
+                  ))}
+                </Select>
+              </FormControl>
+
+              <TextField
+                label="FromUtc (ISO)"
+                value={fromUtc}
+                onChange={(e) => setFromUtc(e.target.value)}
+                sx={{ minWidth: 320 }}
+              />
+              <TextField
+                label="ToUtc (ISO)"
+                value={toUtc}
+                onChange={(e) => setToUtc(e.target.value)}
+                sx={{ minWidth: 320 }}
+              />
+
+              <TextField
+                label="Interval (minutes)"
+                type="number"
+                value={intervalMinutes}
+                onChange={(e) => setIntervalMinutes(Number(e.target.value))}
+                sx={{ width: 160 }}
+              />
+
+              <Button variant="contained" onClick={runSimulation} disabled={!streamId}>
+                Run simulation
+              </Button>
+            </Stack>
+
+            <Stack direction="row" spacing={2} alignItems="center" flexWrap="wrap">
+              {simulationId && <Typography color="text.secondary">SimulationId: {simulationId}</Typography>}
+              {status && <Typography color="text.secondary">Status: {status}</Typography>}
+            </Stack>
+
+            {error && (
+              <Alert severity="error" sx={{ whiteSpace: "pre-wrap" }}>
+                {error}
+              </Alert>
+            )}
+
+            <Divider />
+
+            <Typography variant="subtitle1">2) Workload chart (hours per activity)</Typography>
+            {buckets.length === 0 ? (
+              <Alert severity="info">
+                No buckets yet. Run a simulation. If still empty, check that the stream has events in the selected time range.
+              </Alert>
+            ) : (
+              <Box sx={{ width: "100%", height: 360 }}>
+                <ResponsiveContainer>
+                  <LineChart
+                    data={chartData}
+                    onClick={(state: any) => {
+                      const label = state?.activeLabel as string | undefined;
+                      if (!label) return;
+                      // pick first bucket at this time (for drilldown)
+                      const hit = buckets.find(b => b.intervalStartUtc === label) ?? null;
+                      setSelectedBucket(hit);
+                    }}
+                  >
+                    <XAxis dataKey="t" hide />
+                    <YAxis />
+                    <Tooltip />
+                    <Legend />
+                    {seriesKeys.map((k) => (
+                      <Line key={k} type="monotone" dataKey={k} dot={false} />
+                    ))}
+                  </LineChart>
+                </ResponsiveContainer>
+              </Box>
+            )}
+
+            <Divider />
+
+            <Typography variant="subtitle1">3) Why? (drilldown)</Typography>
+            {!selectedBucket ? (
+              <Alert severity="info">Click in the chart to inspect a bucket explanation.</Alert>
+            ) : (
+              <Card variant="outlined">
+                <CardContent>
+                  <Typography variant="body2" color="text.secondary">
+                    Activity: {activityById[selectedBucket.activityId]?.code ?? selectedBucket.activityId}
+                  </Typography>
+                  <Typography variant="body2" color="text.secondary">
+                    Interval: {selectedBucket.intervalStartUtc} → {selectedBucket.intervalEndUtc}
+                  </Typography>
+                  <Typography variant="body1" sx={{ mt: 1 }}>
+                    Hours: {selectedBucket.hours}
+                  </Typography>
+                  <Typography variant="subtitle2" sx={{ mt: 2 }}>
+                    ExplanationJson
+                  </Typography>
+                  <Box component="pre" sx={{ mt: 1, p: 1.5, bgcolor: "#111", color: "#eee", borderRadius: 1, overflow: "auto" }}>
+                    {selectedBucket.explanationJson}
+                  </Box>
+                </CardContent>
+              </Card>
+            )}
+          </Stack>
+        </CardContent>
+      </Card>
+    </Stack>
+  );
+}
+
