@@ -0,0 +1,302 @@
+import { useMemo, useState } from "react";
+import { useQuery } from "@tanstack/react-query";
+import {
+  Alert,
+  Box,
+  Button,
+  Card,
+  CardContent,
+  Divider,
+  FormControl,
+  InputLabel,
+  MenuItem,
+  Select,
+  Stack,
+  TextField,
+  Typography
+} from "@mui/material";
+import { api } from "../api/client";
+import type { Activity, LatestMappingResponse, Stream } from "../api/types";
+
+type EditableRule = {
+  name: string;
+  eventType: string;
+  conditionExpression: string | null;
+  sortOrder: number;
+  activities: Array<{
+    activityId: string;
+    baseHours: number;
+    unitExpression: string | null;
+    perUnitHours: number;
+    multiplierExpression: string | null;
+  }>;
+};
+
+export default function MappingEditorPage() {
+  const [streamId, setStreamId] = useState<string>("");
+  const [mappingName, setMappingName] = useState<string>("Prototype mapping");
+  const [rules, setRules] = useState<EditableRule[]>([]);
+  const [status, setStatus] = useState<string>("");
+  const [error, setError] = useState<string>("");
+
+  const streamsQ = useQuery({
+    queryKey: ["streams"],
+    queryFn: () => api<Stream[]>("/streams")
+  });
+
+  const activitiesQ = useQuery({
+    queryKey: ["activities"],
+    queryFn: () => api<Activity[]>("/activities")
+  });
+
+  const selectedStream = useMemo(
+    () => streamsQ.data?.find(s => s.id === streamId) ?? null,
+    [streamsQ.data, streamId]
+  );
+
+  async function loadLatest() {
+    setError("");
+    setStatus("Loading latest mapping...");
+    try {
+      const latest = await api<LatestMappingResponse>(`/streams/${streamId}/mappings/latest`);
+
+      // Convert to editable model
+      const raByRule: Record<string, LatestMappingResponse["ruleActivities"]> = {};
+      for (const ra of latest.ruleActivities) {
+        raByRule[ra.mappingRuleId] = raByRule[ra.mappingRuleId] ?? [];
+        raByRule[ra.mappingRuleId].push(ra);
+      }
+
+      const nextRules: EditableRule[] = latest.rules
+        .slice()
+        .sort((a, b) => a.sortOrder - b.sortOrder)
+        .map(r => ({
+          name: r.name,
+          eventType: r.eventType,
+          conditionExpression: r.conditionExpression ?? null,
+          sortOrder: r.sortOrder,
+          activities: (raByRule[r.id] ?? []).map(a => ({
+            activityId: a.activityId,
+            baseHours: a.baseHours,
+            unitExpression: a.unitExpression ?? null,
+            perUnitHours: a.perUnitHours,
+            multiplierExpression: a.multiplierExpression ?? null
+          }))
+        }));
+
+      setRules(nextRules);
+      setMappingName(`Copy of v${latest.version.versionNumber}: ${latest.version.name}`);
+      setStatus("Loaded.");
+    } catch (e: any) {
+      setError(e?.message ?? String(e));
+      setStatus("");
+    }
+  }
+
+  function createCampingTemplate() {
+    const activities = activitiesQ.data ?? [];
+    const reception = activities.find(a => a.code === "Reception");
+    const hk = activities.find(a => a.code === "Housekeeping");
+    if (!reception || !hk) {
+      setError("Missing activities Reception/Housekeeping. Create them in Swagger or seed DB.");
+      return;
+    }
+
+    setRules([
+      {
+        name: "Booking created (camping)",
+        eventType: "CampingBookingCreated",
+        conditionExpression: null,
+        sortOrder: 1,
+        activities: [
+          {
+            activityId: reception.id,
+            baseHours: 0.3,
+            unitExpression: "count($.addOns)",
+            perUnitHours: 0.05,
+            multiplierExpression: null
+          },
+          {
+            activityId: hk.id,
+            baseHours: 0.0,
+            unitExpression: "stayNights($.checkInDate,$.checkOutDate)",
+            perUnitHours: 0.6,
+            multiplierExpression: "cabinTypeFactor($.cabinType)"
+          }
+        ]
+      }
+    ]);
+    setMappingName("Initial camping mapping (prototype)");
+    setStatus("Camping template loaded (editable).");
+    setError("");
+  }
+
+  async function saveNewVersion() {
+    setError("");
+    setStatus("Saving mapping as new version...");
+    try {
+      const payload = {
+        name: mappingName,
+        rules: rules.map(r => ({
+          name: r.name,
+          eventType: r.eventType,
+          conditionExpression: r.conditionExpression,
+          sortOrder: r.sortOrder,
+          activities: r.activities.map(a => ({
+            activityId: a.activityId,
+            baseHours: a.baseHours,
+            unitExpression: a.unitExpression,
+            perUnitHours: a.perUnitHours,
+            multiplierExpression: a.multiplierExpression
+          }))
+        }))
+      };
+
+      await api(`/streams/${streamId}/mappings`, {
+        method: "POST",
+        body: JSON.stringify(payload)
+      });
+      setStatus("Saved new mapping version.");
+    } catch (e: any) {
+      setError(e?.message ?? String(e));
+      setStatus("");
+    }
+  }
+
+  function setRuleField(i: number, patch: Partial<EditableRule>) {
+    setRules(prev => prev.map((r, idx) => (idx === i ? { ...r, ...patch } : r)));
+  }
+
+  function setRuleActivityField(ruleIndex: number, actIndex: number, patch: Partial<EditableRule["activities"][number]>) {
+    setRules(prev =>
+      prev.map((r, idx) =>
+        idx === ruleIndex
+          ? {
+              ...r,
+              activities: r.activities.map((a, j) => (j === actIndex ? { ...a, ...patch } : a))
+            }
+          : r
+      )
+    );
+  }
+
+  const activitiesById = useMemo(() => {
+    const m: Record<string, Activity> = {};
+    for (const a of activitiesQ.data ?? []) m[a.id] = a;
+    return m;
+  }, [activitiesQ.data]);
+
+  return (
+    <Stack spacing={2}>
+      <Typography variant="h5">Mapping Editor</Typography>
+
+      <Card>
+        <CardContent>
+          <Stack spacing={2}>
+            <Typography variant="subtitle1">1) Select stream</Typography>
+            <Stack direction="row" spacing={2} alignItems="center" flexWrap="wrap">
+              <FormControl sx={{ minWidth: 360 }}>
+                <InputLabel id="stream-label">Stream</InputLabel>
+                <Select
+                  labelId="stream-label"
+                  label="Stream"
+                  value={streamId}
+                  onChange={(e) => setStreamId(String(e.target.value))}
+                >
+                  {(streamsQ.data ?? []).map(s => (
+                    <MenuItem key={s.id} value={s.id}>
+                      {s.name} ({s.industry})
+                    </MenuItem>
+                  ))}
+                </Select>
+              </FormControl>
+
+              <Button variant="outlined" onClick={loadLatest} disabled={!streamId}>
+                Load latest mapping
+              </Button>
+
+              <Button variant="contained" onClick={createCampingTemplate} disabled={activitiesQ.isLoading}>
+                Load camping template
+              </Button>
+            </Stack>
+
+            {selectedStream && (
+              <Typography variant="body2" color="text.secondary">
+                Selected: {selectedStream.name} — Source: {selectedStream.sourceSystem} — Industry: {selectedStream.industry}
+              </Typography>
+            )}
+
+            <Divider />
+
+            <Typography variant="subtitle1">2) Edit mapping version</Typography>
+            <TextField
+              label="Mapping name"
+              value={mappingName}
+              onChange={(e) => setMappingName(e.target.value)}
+              fullWidth
+            />
+
+            {rules.length === 0 && (
+              <Alert severity="info">
+                No rules loaded yet. Click <b>Load latest mapping</b> or <b>Load camping template</b>.
+              </Alert>
+            )}
+
+            {rules.map((r, i) => (
+              <Card key={i} variant="outlined">
+                <CardContent>
+                  <Stack spacing={1.5}>
+                    <Stack direction="row" spacing={2} flexWrap="wrap">
+                      <TextField
+                        label="Rule name"
+                        value={r.name}
+                        onChange={(e) => setRuleField(i, { name: e.target.value })}
+                        sx={{ minWidth: 280 }}
+                      />
+                      <TextField
+                        label="EventType"
+                        value={r.eventType}
+                        onChange={(e) => setRuleField(i, { eventType: e.target.value })}
+                        sx={{ minWidth: 260 }}
+                      />
+                      <TextField
+                        label="Condition (optional)"
+                        value={r.conditionExpression ?? ""}
+                        onChange={(e) => setRuleField(i, { conditionExpression: e.target.value || null })}
+                        sx={{ minWidth: 320 }}
+                      />
+                      <TextField
+                        label="SortOrder"
+                        type="number"
+                        value={r.sortOrder}
+                        onChange={(e) => setRuleField(i, { sortOrder: Number(e.target.value) })}
+                        sx={{ width: 120 }}
+                      />
+                    </Stack>
+
+                    <Box>
+                      <Typography variant="subtitle2">Activities</Typography>
+                      <Stack spacing={1}>
+                        {r.activities.map((a, j) => (
+                          <Card key={j} variant="outlined">
+                            <CardContent>
+                              <Stack direction="row" spacing={2} flexWrap="wrap" alignItems="center">
+                                <FormControl sx={{ minWidth: 240 }}>
+                                  <InputLabel id={`act-${i}-${j}`}>Activity</InputLabel>
+                                  <Select
+                                    labelId={`act-${i}-${j}`}
+                                    label="Activity"
+                                    value={a.activityId}
+                                    onChange={(e) => setRuleActivityField(i, j, { activityId: String(e.target.value) })}
+                                  >
+                                    {(activitiesQ.data ?? []).map(x => (
+                                      <MenuItem key={x.id} value={x.id}>
+                                        {x.code} — {x.name}
+                                      </MenuItem>
+                                    ))}
+                                  </Select>
+                                </FormControl>
+
+                                <TextField
+                                  label="BaseHours"
+                                  type="number"
+                                  value={a.baseHours}
+                                  onChange={(e) => setRuleActivityField(i, j, { baseHours: Number(e.target.value) })}
+                                  sx={{ width: 140 }}
+                                />
+                                <TextField
+                                  label="UnitExpression"
+                                  value={a.unitExpression ?? ""}
+                                  onChange={(e) => setRuleActivityField(i, j, { unitExpression: e.target.value || null })}
+                                  sx={{ minWidth: 260 }}
+                                />
+                                <TextField
+                                  label="PerUnitHours"
+                                  type="number"
+                                  value={a.perUnitHours}
+                                  onChange={(e) => setRuleActivityField(i, j, { perUnitHours: Number(e.target.value) })}
+                                  sx={{ width: 160 }}
+                                />
+                                <TextField
+                                  label="MultiplierExpression"
+                                  value={a.multiplierExpression ?? ""}
+                                  onChange={(e) => setRuleActivityField(i, j, { multiplierExpression: e.target.value || null })}
+                                  sx={{ minWidth: 260 }}
+                                />
+                              </Stack>
+                              <Typography variant="caption" color="text.secondary">
+                                Selected: {activitiesById[a.activityId]?.code ?? a.activityId}
+                              </Typography>
+                            </CardContent>
+                          </Card>
+                        ))}
+                      </Stack>
+                    </Box>
+                  </Stack>
+                </CardContent>
+              </Card>
+            ))}
+
+            <Divider />
+
+            <Stack direction="row" spacing={2} alignItems="center" flexWrap="wrap">
+              <Button variant="contained" onClick={saveNewVersion} disabled={!streamId || rules.length === 0}>
+                Save as new mapping version
+              </Button>
+              {status && <Typography color="text.secondary">{status}</Typography>}
+            </Stack>
+
+            {error && (
+              <Alert severity="error" sx={{ whiteSpace: "pre-wrap" }}>
+                {error}
+              </Alert>
+            )}
+          </Stack>
+        </CardContent>
+      </Card>
+    </Stack>
+  );
+}
